# Copy this to ".env" on the VPS and fill in your values:  cp .env.example .env
# (.env is gitignored — your real values are never committed.)

# The public domain that points (DNS A record) at this VPS's IP.
# Caddy issues an HTTPS certificate for exactly this name.
PORTAL_DOMAIN=portal.humiley.com

# The first admin account, created automatically on a fresh database.
# Use the Microsoft 365 email that will sign in as Admin.
TK_ADMIN_EMAIL=tony.nguyen@humiley.com
TK_ADMIN_NAME=Tony Nguyen
