# Copy this to ".env" on the VPS and fill in your values:  cp .env.example .env
# (.env is gitignored — your real values are never committed.)

# The public domain that points (DNS A record) at this VPS's IP.
# Caddy issues an HTTPS certificate for exactly this name.
PORTAL_DOMAIN=portal.humiley.com

# The first admin account, created automatically on a fresh database.
# Use the Microsoft 365 email that will sign in as Admin.
TK_ADMIN_EMAIL=tony.nguyen@humiley.com
TK_ADMIN_NAME=Tony Nguyen

# Signature-PIN pepper (21 CFR Part 11). A secret kept OUTSIDE the database so that a leaked
# database file alone cannot be used to brute-force employees' signing PINs offline.
# You do NOT need to set this by hand — ./update.sh generates it once and writes it here.
# If you set it yourself, use a long random value (openssl rand -hex 32) and NEVER change it
# afterwards, or every already-enrolled PIN will stop verifying. Keep a backup of this file.
# TK_ESIGN_PEPPER=

# Procurement single-sign-on secret. Procurement is an app of this portal (like HR/CRM): a
# signed-in user opens it with no second login. ./update.sh generates this once; when you deploy
# the Procurement app, set its PORTAL_SSO_SECRET to the SAME value.
# TK_SSO_SECRET=

# ── Procurement (an app of this portal, served at /procurement) ───────────────────────────────
# These are generated once into .env by ./update.sh — you do NOT need to set them by hand.
# AUTH_SECRET       = Auth.js session secret for Procurement.
# POSTGRES_PASSWORD = the Procurement database password.
# APP_URL           = the public Procurement URL (defaults to https://<PORTAL_DOMAIN>/procurement).
# BOOTSTRAP_ADMIN_EMAIL = the first Procurement admin (only used on ./update.sh --bootstrap).
# AUTH_SECRET=
# POSTGRES_PASSWORD=
# APP_URL=https://portal.humiley.com/procurement
# BOOTSTRAP_ADMIN_EMAIL=
