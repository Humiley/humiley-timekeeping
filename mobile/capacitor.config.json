{
  "appId": "com.humiley.portal",
  "appName": "Humiley",
  "webDir": "www",
  "server": {
    "url": "https://portal.humiley.com",
    "cleartext": false,
    "allowNavigation": [
      "portal.humiley.com",
      "login.microsoftonline.com",
      "*.microsoftonline.com",
      "login.live.com",
      "*.msauth.net",
      "*.msftauth.net",
      "graph.microsoft.com"
    ]
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0b2649",
    "limitsNavigationsToAppBoundDomains": false
  },
  "plugins": {
    "CapacitorHttp": { "enabled": true },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0b2649",
      "showSpinner": false
    }
  }
}
