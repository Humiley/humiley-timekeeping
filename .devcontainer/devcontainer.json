{
  "name": "Humiley Timekeeping",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Humiley Timekeeping",
      "visibility": "public",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "nohup python3 app.py > /tmp/tk.log 2>&1 &",
  "postAttachCommand": "bash -lc 'pgrep -f \"python3 app.py\" >/dev/null || (nohup python3 app.py > /tmp/tk.log 2>&1 &)'"
}
